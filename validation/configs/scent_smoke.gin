# SCENT smoke test — scent_6td3.gin shrunk to validate the full loop end-to-end
# with the CHEAP mock oracle (no GPU docking). Tiny rounds/batch/steps so it runs
# on a laptop/login node in minutes. The bridge still shells out to the `rgfn` env
# (which needs `module load cuda/11.8.0` for dgl), exactly like the FragGFN smoke.
#
#   conda run -n scent python validation/generators/scent/run_scent_al.py \
#       --cfg validation/configs/scent_smoke.gin \
#       --seed-csv experiments/active_learning/6td3/seed_6td3.csv \
#       --root-dir /tmp/scent_smoke

include 'configs/scent_base.gin'
include 'configs/envs/settings/small.gin'

beta = 8
WandbLogger.mode = 'offline'

proxy/gin.singleton.constructor = @LearnedDockingProxy
train_proxy = @proxy/gin.singleton()
valid_proxy = %train_proxy
LearnedDockingProxy.higher_is_better = False
LearnedDockingProxy.max_epochs = 5
LearnedDockingProxy.patience = 3
LearnedDockingProxy.batch_size = 64

Trainer.n_iterations = 3
Trainer.valid_every_n_iterations = 100000000
trainer/gin.singleton.constructor = @Trainer
trainer = @trainer/gin.singleton()

ScentActiveLearningLoop.trainer = %trainer
ScentActiveLearningLoop.proxy = %train_proxy
ScentActiveLearningLoop.n_rounds = 1
ScentActiveLearningLoop.query_batch_size = 4
ScentActiveLearningLoop.sample_oversample = 4.0
ScentActiveLearningLoop.top_k = 2
ScentActiveLearningLoop.system = '6td3'
ScentActiveLearningLoop.oracle_threshold = -2.0
ScentActiveLearningLoop.oracle_higher_is_better = False

# Cheap mock oracle (no docking) — the bridge still runs under the rgfn env.
ScentActiveLearningLoop.oracle_env = 'rgfn'
ScentActiveLearningLoop.score_script = 'scripts/score_batch.py'
ScentActiveLearningLoop.oracle_name = 'mock'
ScentActiveLearningLoop.oracle_args = {}
